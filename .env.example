# ============================================================
# Nexe — Global Environment Variables
# Copy to .env and fill in values
# ============================================================

# General
NEXE_ENV=development
NEXE_LOG_LEVEL=debug

# JWT
NEXE_JWT_SECRET=
NEXE_JWT_ACCESS_TTL=15m
NEXE_JWT_REFRESH_TTL=168h

# Database
NEXE_DB_URL=postgresql://decatron_user@localhost:5432/nexe_dev?sslmode=disable
NEXE_REDIS_URL=redis://localhost:6379/3

# Twitch OAuth
NEXE_TWITCH_CLIENT_ID=
NEXE_TWITCH_CLIENT_SECRET=
NEXE_TWITCH_REDIRECT_URI=https://api.nexe.decatron.net/auth/twitch/callback
NEXE_TWITCH_EVENTSUB_SECRET=

# Cloudflare R2
NEXE_R2_ACCOUNT_ID=
NEXE_R2_ACCESS_KEY=
NEXE_R2_SECRET_KEY=
NEXE_R2_BUCKET=nexe-uploads
NEXE_R2_PUBLIC_URL=https://cdn.nexe.decatron.net

# Email (SMTP)
NEXE_EMAIL_FROM=noreply@nexe.decatron.net
NEXE_EMAIL_SMTP_HOST=
NEXE_EMAIL_SMTP_PORT=587
NEXE_EMAIL_SMTP_USER=
NEXE_EMAIL_SMTP_PASS=

# Service ports (defaults)
NEXE_GATEWAY_PORT=8090
NEXE_GUILDS_PORT=8082
NEXE_MESSAGING_PORT=8083
NEXE_PRESENCE_PORT=8084

# Internal service URLs
NEXE_GUILDS_URL=http://localhost:8082
NEXE_MESSAGING_URL=http://localhost:8083
NEXE_PRESENCE_URL=http://localhost:8084

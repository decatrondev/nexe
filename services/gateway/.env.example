NEXE_ENV=development
NEXE_GATEWAY_PORT=8090
NEXE_REDIS_URL=redis://localhost:6379/3
NEXE_TWITCH_CLIENT_ID=
NEXE_TWITCH_CLIENT_SECRET=
NEXE_TWITCH_REDIRECT_URI=https://api.nexe.decatron.net/auth/twitch/callback
NEXE_FRONTEND_URL=https://nexeapp.decatron.net

# REQUIRED — service will not start without these
NEXE_DB_URL=postgresql://user:password@localhost:5432/nexe_dev?sslmode=disable
NEXE_JWT_SECRET=
NEXE_TWITCH_EVENTSUB_SECRET=

# R2 Storage (optional — falls back to local if not set)
NEXE_R2_ENDPOINT=
NEXE_R2_ACCESS_KEY_ID=
NEXE_R2_SECRET_ACCESS_KEY=
NEXE_R2_BUCKET=nexe-uploads
NEXE_R2_PUBLIC_URL=

{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Nexe",
  "version": "0.0.1",
  "identifier": "net.decatron.nexe",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "Nexe",
        "width": 1280,
        "height": 800,
        "minWidth": 940,
        "minHeight": 560,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/decatrondev/nexe/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEEzOENCQjgwRjM2MzAwRDMKUldUVEFHUHpnTHVNbzVRVXd3VlJraktPQ0JvNEtjZGxXc2Qrc0Y4VDZPcW1DMVdHS1FJc1FCM0wK"
    }
  }
}
